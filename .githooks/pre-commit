#!/bin/bash

# Temporary files to store line counts
TEMP_COUNT_FILE=".git/ai_lines_count.tmp"
TEMP_MANUAL_FILE=".git/manual_lines_count.tmp"
rm -f "$TEMP_COUNT_FILE"
rm -f "$TEMP_MANUAL_FILE"

total_ai_lines=0
total_manual_lines=0

# Get all staged file names
staged_files=$(git diff --cached --name-only)

for file in $staged_files; do
    if [ -f "$file" ]; then

        # Count AI lines inside tags
        # Supports: // (JS/Java/C), -- (SQL), # (Python/Shell/YAML)
        ai_lines=$(awk '
            /\/\/ START OF AI GENERATED/ || /-- START OF AI GENERATED/ || /# START OF AI GENERATED/ {flag=1; next}
            /\/\/ END OF AI GENERATED/ || /-- END OF AI GENERATED/ || /# END OF AI GENERATED/ {flag=0; next}
            flag {count++}
            END {print count+0}
        ' "$file")

        total_ai_lines=$((total_ai_lines + ai_lines))

        # Count only ADDED lines (+ lines) excluding file header
        file_added_lines=$(git diff --cached -- "$file" | grep "^+" | grep -v "^+++" | wc -l | tr -d ' ')

        # Manual LOC = total added lines - AI added lines
        manual_lines=$((file_added_lines - ai_lines))
        if [ "$manual_lines" -lt 0 ]; then manual_lines=0; fi
        total_manual_lines=$((total_manual_lines + manual_lines))

        # Strip AI tags before committing (clean code goes to Git)
        if [[ "$OSTYPE" == "darwin"* ]]; then
            sed -i '' '/START OF AI GENERATED/d; /END OF AI GENERATED/d' "$file"
        else
            sed -i '/START OF AI GENERATED/d; /END OF AI GENERATED/d' "$file"
        fi

        # Re-stage the cleaned file
        git add "$file"
    fi
done

# Save counts to temp files
echo "$total_ai_lines" > "$TEMP_COUNT_FILE"
echo "$total_manual_lines" > "$TEMP_MANUAL_FILE"

exit 0
